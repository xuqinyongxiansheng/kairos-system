# ============================================================
# 鸿蒙小雨 v4.1 环境变量配置模板
# 复制为 .env 并修改相应值后启动服务
# ============================================================

# ---------- 运行环境 ----------
GEMMA4_SERVER_ENV=development
GEMMA4_SERVER_DEBUG=true
GEMMA4_SERVER_HOST=127.0.0.1
GEMMA4_SERVER_PORT=8000
GEMMA4_SERVER_WORKERS=1

# ---------- Ollama LLM 服务 ----------
GEMMA4_OLLAMA_HOST=http://127.0.0.1:11434
GEMMA4_OLLAMA_DEFAULT_MODEL=gemma4:e4b
GEMMA4_OLLAMA_TIMEOUT=180
GEMMA4_OLLAMA_MAX_RETRIES=2
GEMMA4_OLLAMA_MAX_HISTORY_MESSAGES=20
GEMMA4_OLLAMA_CONTEXT_TOKENS=4096
GEMMA4_OLLAMA_TEMPERATURE=0.6
GEMMA4_OLLAMA_TOP_P=0.85
GEMMA4_OLLAMA_TOP_K=40

# ---------- 安全设置 ----------
# JWT认证（生产环境必须启用）
GEMMA4_SECURITY_AUTH_ENABLED=false
GEMMA4_SECURITY_JWT_SECRET=
GEMMA4_SECURITY_JWT_ALGORITHM=HS256
GEMMA4_SECURITY_JWT_EXPIRE_HOURS=24

# 速率限制
GEMMA4_SECURITY_RATE_LIMIT_ENABLED=true
GEMMA4_SECURITY_RATE_LIMIT_REQUESTS=100
GEMMA4_SECURITY_RATE_LIMIT_WINDOW=60

# CORS允许来源（逗号分隔）
GEMMA4_SECURITY_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
GEMMA4_SECURITY_HTTPS_ENFORCE=false
GEMMA4_SECURITY_SIGNATURE_ENABLED=false
GEMMA4_SECURITY_SIGNATURE_SECRET=

# IP控制
GEMMA4_SECURITY_IP_WHITELIST_ENABLED=false
GEMMA4_SECURITY_IP_BLACKLIST_ENABLED=false

# 审计日志
GEMMA4_SECURITY_AUDIT_LOG_ENABLED=true
GEMMA4_SECURITY_AUDIT_LOG_FILE=./log/audit.log

# 响应缓存
GEMMA4_SECURITY_RESPONSE_CACHE_ENABLED=true
GEMMA4_SECURITY_RESPONSE_CACHE_TTL=300

# ---------- API设置 ----------
GEMMA4_API_VERSION=v4.0.0
GEMMA4_API_PREFIX=/api
GEMMA4_API_CHAT_MAX_MESSAGE_LENGTH=32000
GEMMA4_API_METRICS_ENABLED=true
GEMMA4_API_METRICS_PATH=/metrics

# ---------- 记忆系统 ----------
GEMMA4_MEMORY_MAX_SESSIONS=50
GEMMA4_MEMORY_SESSION_TTL_DAYS=30
GEMMA4_MEMORY_VECTOR_DB_PATH=./data/vector_store
GEMMA4_MEMORY_KNOWLEDGE_GRAPH_PATH=./data/knowledge_graph.json

# ---------- 日志设置 ----------
GEMMA4_LOG_LEVEL=INFO
GEMMA4_LOG_FILE_PATH=./log/hmyx.log
GEMMA4_LOG_MAX_SIZE_MB=50
GEMMA4_LOG_BACKUP_COUNT=5
GEMMA4_LOG_CONSOLE_OUTPUT=true

# ---------- 兼容旧版（无前缀）----------
# GEMMA4_ENV=development
# GEMMA4_MODEL=gemma4:e4b
# GEMMA4_JWT_SECRET=
